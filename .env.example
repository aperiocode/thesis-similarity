# ── Database — SQLite only ───────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./skripsi.db

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=skripsi_embeddings

# ── Sentence Transformers model ───────────────────────────────────────────────
MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
ABSTRAK_MAX_CHARS=300

# ── CORS (pisahkan dengan koma jika lebih dari satu) ─────────────────────────
ALLOWED_ORIGINS=http://localhost:8000

# ── Token sinkronisasi Laravel ───────────────────────────────────────────────
# WAJIB diganti! Minimal 16 karakter.
# Generate: openssl rand -hex 32
SYNC_SECRET=ganti-dengan-token-acak-minimal-32-karakter

# ── Concurrency control ───────────────────────────────────────────────────────
INFERENCE_CONCURRENCY=4
BULK_SYNC_CHUNK_SIZE=100

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Offline mode (aktifkan di Docker agar model tidak didownload ulang) ───────
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
