PORT=8181

DATABASE_URL=sqlite+aiosqlite:///./skripsi.db
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=skripsi_embeddings

MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
ABSTRAK_MAX_CHARS=300

ALLOWED_ORIGINS=http://localhost:8000

# WAJIB diganti. Minimal 16 karakter.
# Generate: openssl rand -hex 32
SYNC_SECRET=ganti-dengan-token-acak-minimal-32-karakter

INFERENCE_CONCURRENCY=4
BULK_SYNC_CHUNK_SIZE=100

LOG_LEVEL=INFO

HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
